# ══════════════════════════════════════════════════════════════
#  LEGAL SYSTEM — Configurações de Ambiente
#  Copie este arquivo para .env e ajuste os valores
#  NUNCA commite o .env real (está no .gitignore)
# ══════════════════════════════════════════════════════════════

# === Django Core ===
# Gere uma chave segura com: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=django-insecure-CHANGE-THIS-IN-PRODUCTION-use-python-secrets-token
DEBUG=True
ENVIRONMENT=development

# Em produção: IP do servidor + domínio (sem http://)
# ALLOWED_HOSTS=192.168.1.100,meuescritorio.local,localhost
ALLOWED_HOSTS=localhost,127.0.0.1

# === Database ===
# Desenvolvimento: SQLite local
DATABASE_URL=sqlite:///db.sqlite3

# Produção: PostgreSQL
# Crie o banco antes:
#   createdb legal_system
#   psql -c "CREATE USER legal_user WITH PASSWORD 'SenhaForte!23';"
#   psql -c "GRANT ALL PRIVILEGES ON DATABASE legal_system TO legal_user;"
# DATABASE_URL=postgresql://legal_user:SenhaForte!23@localhost:5432/legal_system

# === CORS — Frontend permitido ===
# Desenvolvimento
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Produção: acrescente o IP/porta do frontend na rede interna
# CORS_ALLOWED_ORIGINS=http://192.168.1.10:80,http://meuescritorio.local

# === OAB Configuration ===
# Dados do advogado principal (busca padrão em publicações)
# Cada advogado cadastrado no sistema herda seus próprios dados via UserProfile
OAB_NUMBER=507553
ADVOGADA_NOME=Vitoria Rocha de Morais

MASTER_USERNAME='master.vitoria'
MASTER_EMAIL='master@escritorio.com'
MASTER_PASSWORD='SenhaForte!123'
MASTER_FIRST_NAME='Vitoria'

SUPERUSER_USERNAME=su
SENHA_SUPERUSER=Carlos19737
# Nota: O sistema aplica DOIS filtros nas publicações:
# 1. POSITIVO: Garante menção à OAB/nome no texto (evita falsos positivos)
# 2. NEGATIVO: Exclui publicações de outras advogadas com nomes similares
#    (ex: LÚCIA VITÓRIA ROCHA DO NASCIMENTO — OAB 407729/SP)
# Ajuste em services/pje_comunica.py → EXCLUDED_LAWYERS

# === Email ===
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# === Logs e debug ===
LOG_API_REQUESTS=False

# === JWT (sessão) ===
# Tempo de validade em horas (aceita decimal)
# ACCESS default: 8h
# REFRESH default: 168h (7 dias)
JWT_ACCESS_TOKEN_HOURS=8
JWT_REFRESH_TOKEN_HOURS=168

# ══════════════════════════════════════════════════════════════
#  PRODUÇÃO — descomente e ajuste quando for ao ar no servidor
# ══════════════════════════════════════════════════════════════
# DEBUG=False
# ENVIRONMENT=production
#
# HTTPS (somente se tiver certificado SSL/TLS no servidor):
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
