# ==========================================================
# Legal System - Backend environment template
# ==========================================================
# Copy this file to backend/.env and replace placeholders.
# Never commit backend/.env with real values.
#
# macOS/Linux:
#   cp backend/.env.example backend/.env
# Windows PowerShell:
#   Copy-Item backend/.env.example backend/.env

# Core
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=True
ENVIRONMENT=development

# Hosts/CORS (comma-separated)
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Security flags (set True in production behind HTTPS)
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# Database
# Dev (SQLite):
DATABASE_URL=sqlite:///db.sqlite3
# Prod (PostgreSQL) example:
# DATABASE_URL=postgresql://legal_user:replace-password@127.0.0.1:5432/legal_system

# Publications / PJe Comunica
PJE_COMUNICA_API_URL=https://comunicaapi.pje.jus.br/api/v1/comunicacao
PJE_COMUNICA_TIMEOUT_SECONDS=15
PJE_COMUNICA_MAX_RETRIES=2
PJE_COMUNICA_RETRY_BACKOFF_SECONDS=0.75,2.0
PJE_COMUNICA_DEFAULT_TRIBUNAIS=TJSP,TRF3,TRT2,TRT15,TJMG

# Default identity fallback for publication queries
OAB_NUMBER=123456
ADVOGADA_NOME=Nome Sobrenome

# Exclusion rules for similar names/OABs (comma-separated)
PJE_COMUNICA_EXCLUDED_LAWYERS_OABS=
PJE_COMUNICA_EXCLUDED_LAWYERS_KEYWORDS=

# Master bootstrap account (replace in real environments)
MASTER_USERNAME=master
MASTER_EMAIL=master@local.invalid
MASTER_PASSWORD=replace-master-password
MASTER_FIRST_NAME=Master

# Optional compatibility keys
SUPERUSER_USERNAME=su
SENHA_SUPERUSER=replace-superuser-password

# JWT
JWT_ACCESS_TOKEN_HOURS=8
JWT_REFRESH_TOKEN_HOURS=168

# Optional logs
LOG_API_REQUESTS=False
